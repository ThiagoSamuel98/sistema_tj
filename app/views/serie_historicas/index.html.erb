<% provide :title, "Série Histórica" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-2 text-gray-800">
            <i class="fas fa-history me-2"></i>Série Histórica
          </h1>
          <p class="text-muted">Registros históricos dos indicadores</p>
        </div>
        <%= link_to "Novo Registro", new_serie_historica_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>

  <!-- Tabela -->
  <div class="card shadow">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>Ano</th>
              <th>Indicador</th>
              <th>Tipo</th>
              <th>Valor</th>
              <th>Valor Original</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @serie_historicas.each do |sh| %>
              <tr>
                <td><%= sh.ano %></td>
                <td>
                  <div class="fw-bold"><%= truncate(sh.indicador.indicador, length: 40) %></div>
                </td>
                <td>
                  <span class="badge <%= sh.indicador.tipo == 'nacional' ? 'bg-info' : 'bg-warning' %>">
                    <%= sh.indicador.tipo.titleize %>
                  </span>
                </td>
                <td><%= sh.valor || 'N/A' %></td>
                <td><small class="text-muted"><%= sh.valor_original || '-' %></small></td>
                <td>
                  <span class="badge <%= sh.status == 'indisponivel' ? 'bg-secondary' : 'bg-success' %>">
                    <%= sh.status || 'disponivel' %>
                  </span>
                </td>
                <td>
                  <div class="btn-group btn-group-sm" role="group">
                    <%= link_to "Editar", edit_serie_historica_path(sh), class: "btn btn-outline-secondary" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    
    <!-- Paginação -->
    <% if @serie_historicas.total_pages > 1 %>
      <div class="card-footer bg-white">
        <nav aria-label="Page navigation">
          <ul class="pagination justify-content-center mb-0">
            <%= paginate @serie_historicas %>
          </ul>
        </nav>
      </div>
    <% end %>
  </div>
</div>
