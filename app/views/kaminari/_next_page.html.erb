<%# Link para a próxima página - Kaminari + Bootstrap 5 %>
<% if current_page.last? %>
  <li class="page-item disabled">
    <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
      <%= raw(t 'views.pagination.next').html_safe %>
    </a>
  </li>
<% else %>
  <li class="page-item">
    <%= link_to raw(t 'views.pagination.next').html_safe, url, rel: 'next', remote: remote, class: 'page-link' %>
  </li>
<% end %>
