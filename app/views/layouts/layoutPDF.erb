<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        color: #333;
        line-height: 1.6;
        background-color: #fff;
      }

      .container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
      }

      h1 {
        font-size: 24px;
        margin-bottom: 20px;
        color: #1a1a1a;
        border-bottom: 2px solid #d32f2f;
        padding-bottom: 10px;
      }

      .metadata {
        background-color: #f5f5f5;
        padding: 15px;
        margin-bottom: 20px;
        border-left: 4px solid #d32f2f;
      }

      .metadata p {
        margin: 5px 0;
        font-size: 13px;
      }

      .divider {
        border-top: 1px solid #ddd;
        margin: 20px 0;
      }

      .conteudo {
        margin: 20px 0;
        line-height: 1.8;
      }

      .footer {
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #ddd;
        font-size: 12px;
        color: #666;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>