<!DOCTYPE html>
<html class="h-full bg-slate-50">
  <head>
    <title>SGP - Sistema de Gestão de Processos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Chamamos o Tailwind e as Fontes apenas UMA vez cada %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="h-full antialiased text-slate-900">
    <nav class="bg-red-900 shadow-lg border-b border-red-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <span class="text-white font-bold text-xl tracking-tight">⚖️ TJPI <span class="font-light text-red-200">| Digital</span></span>
          </div>
          <div class="flex items-center space-x-4">
            <span class="text-red-200 text-sm">Olá, <%= current_user_name %></span>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
      <%= yield %>
    </main>
  </body>
</html>
