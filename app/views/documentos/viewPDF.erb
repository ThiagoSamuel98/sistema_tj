<h1><%= documento.titulo %></h1>
<div class="divider"></div>

<p><strong>Número do Documento:</strong> <%= documento.numero %></p>
<p><strong>Data:</strong> <%= l(documento.created_at, format: :long) %></p>
<p><strong>Autor:</strong> <%= documento.autor %></p>

<div class="divider"></div>

<div class="conteudo">
  <%= simple_format(documento.conteudo) %>
</div>

<div class="footer">
  <p>Sistema de Gestão Documental - TJ Piauí</p>
  <p>Documento gerado em <%= l(Time.current, format: :long) %></p>
</div>