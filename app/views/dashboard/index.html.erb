<% provide :title, "Dashboard" %>

<div class="container-fluid">
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h3 mb-2 text-gray-800">
        <i class="fas fa-chart-line me-2"></i>Dashboard
      </h1>
      <p class="text-muted">Visão geral dos indicadores do TJ-PI</p>
    </div>
  </div>

  <!-- Filtro de Ano -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm border-start-primary">
        <div class="card-body">
          <%= form_with url: dashboard_path, method: :get, local: true do %>
            <label class="form-label fw-bold">
              <i class="fas fa-calendar me-1"></i>Ano de Referência
            </label>
            <select name="ano" class="form-select" onchange="this.form.submit()">
              <% @anos_disponiveis.each do |ano| %>
                <option value="<%= ano %>" <%= 'selected' if ano == @ano %>>
                  <%= ano %>
                </option>
              <% end %>
            </select>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Cards de KPI -->
  <div class="row mb-4">
    <!-- Total Indicadores -->
    <div class="col-xl-4 col-md-6 mb-4">
      <div class="card bg-primary text-white shadow h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <div class="text-uppercase small fw-bold mb-1">Total Indicadores</div>
              <div class="h2 mb-0"><%= @total_indicadores %></div>
              <small class="text-white-50">
                <%= @indicadores_nacionais %> nacionais, <%= @indicadores_institucionais %> institucionais
              </small>
            </div>
            <div class="text-white-50">
              <i class="fas fa-chart-bar fa-3x"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Gráfico Pizza: Tipo -->
    <div class="col-xl-4 col-md-6 mb-4">
      <div class="card shadow h-100">
        <div class="card-header bg-white py-3">
          <h6 class="m-0 fw-bold text-primary">
            <i class="fas fa-chart-pie me-2"></i>Indicadores por Tipo
          </h6>
        </div>
        <div class="card-body">
          <canvas id="tipoChart" style="max-height: 200px;"></canvas>
        </div>
      </div>
    </div>

    <!-- Cards de Cobertura -->
    <div class="col-xl-4 col-md-12 mb-4">
      <div class="card shadow h-100">
        <div class="card-header bg-white py-3">
          <h6 class="m-0 fw-bold text-success">
            <i class="fas fa-check-circle me-2"></i>Cobertura de Dados
          </h6>
        </div>
        <div class="card-body">
          <div class="mb-4">
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Série Histórica (<%= @ano %>)</span>
              <span class="fw-bold text-success">
                <%= @historico.count %> / <%= @total_indicadores %>
              </span>
            </div>
            <div class="progress" style="height: 10px;">
              <div class="progress-bar bg-success" role="progressbar" 
                   style="width: <%= (@total_indicadores > 0 ? (@historico.count.to_f / @total_indicadores * 100) : 0) %>%">
              </div>
            </div>
          </div>
          
          <div class="mb-4">
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Metas (<%= @ano %>)</span>
              <span class="fw-bold text-info">
                <%= @metas.count %> / <%= @total_indicadores %>
              </span>
            </div>
            <div class="progress" style="height: 10px;">
              <div class="progress-bar bg-info" role="progressbar" 
                   style="width: <%= (@total_indicadores > 0 ? (@metas.count.to_f / @total_indicadores * 100) : 0) %>%">
              </div>
            </div>
          </div>
          
          <div class="mt-auto">
            <div class="alert alert-light border mb-0">
              <small class="text-muted">
                <i class="fas fa-info-circle me-1"></i>
                <%= @total_indicadores - @historico.count - @metas.count %> indicadores sem dados em <%= @ano %>
              </small>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Gráfico de Evolução -->
  <div class="row mb-4">
    <div class="col-lg-8">
      <div class="card shadow">
        <div class="card-header bg-white py-3">
          <h6 class="m-0 fw-bold text-primary">
            <i class="fas fa-chart-line me-2"></i>Evolução de Registros - Série Histórica
          </h6>
        </div>
        <div class="card-body">
          <canvas id="evolucaoChart" style="max-height: 300px;"></canvas>
        </div>
      </div>
    </div>
    
    <div class="col-lg-4">
      <div class="card shadow h-100">
        <div class="card-header bg-white py-3">
          <h6 class="m-0 fw-bold text-info">
            <i class="fas fa-bullseye me-2"></i>Evolução de Metas
          </h6>
        </div>
        <div class="card-body">
          <canvas id="metasChart" style="max-height: 300px;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabela: Últimos Indicadores -->
  <div class="row">
    <div class="col-12">
      <div class="card shadow">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
          <h6 class="m-0 fw-bold text-primary">
            <i class="fas fa-table me-2"></i>Indicadores com Dados em <%= @ano %>
          </h6>
          <%= link_to "Ver todos", indicadores_path, class: "btn btn-sm btn-primary" %>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th>Indicador</th>
                  <th>Tipo</th>
                  <th>Periodicidade</th>
                  <th>Valor (<%= @ano %>)</th>
                  <th>Meta</th>
                  <th>Status</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% @indicadores_com_dados.each do |indicador| %>
                  <% historico = @historico[indicador.id] %>
                  <% meta = @metas[indicador.id] %>
                  <tr>
                    <td>
                      <div class="fw-bold"><%= truncate(indicador.indicador, length: 50) %></div>
                    </td>
                    <td>
                      <span class="badge <%= indicador.tipo == 'nacional' ? 'bg-info' : 'bg-warning' %>">
                        <%= indicador.tipo.titleize %>
                      </span>
                    </td>
                    <td><%= indicador.periodicidade || 'N/A' %></td>
                    <td>
                      <% if historico %>
                        <span class="text-primary fw-bold"><%= truncate(historico.valor.to_s, length: 20) %></span>
                      <% else %>
                        <span class="text-muted">N/A</span>
                      <% end %>
                    </td>
                    <td>
                      <% if meta %>
                        <span class="text-success"><%= truncate(meta.descricao_da_meta.to_s, length: 20) %></span>
                      <% else %>
                        <span class="text-muted">N/A</span>
                      <% end %>
                    </td>
                    <td>
                      <% if historico && meta %>
                        <span class="badge bg-success">Completo</span>
                      <% elsif historico || meta %>
                        <span class="badge bg-warning">Parcial</span>
                      <% else %>
                        <span class="badge bg-secondary">Sem dados</span>
                      <% end %>
                    </td>
                    <td>
                      <%= link_to "Ver", indicador, class: "btn btn-sm btn-outline-primary" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Scripts dos Gráficos -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // Configuração comum
  Chart.defaults.font.family = "'Segoe UI', 'Helvetica', 'Arial', sans-serif";
  Chart.defaults.color = '#858796';

  // Gráfico de Pizza - Tipo
  const tipoCtx = document.getElementById('tipoChart').getContext('2d');
  new Chart(tipoCtx, {
    type: 'doughnut',
    data: {
      labels: ['Nacional', 'Institucional'],
      datasets: [{
        data: [<%= @indicadores_nacionais %>, <%= @indicadores_institucionais %>],
        backgroundColor: ['#4e73df', '#36b9cc'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { 
          position: 'bottom',
          labels: { padding: 15 }
        }
      }
    }
  });

  // Gráfico de Linha - Evolução Série Histórica
  const evolucaoCtx = document.getElementById('evolucaoChart').getContext('2d');
  new Chart(evolucaoCtx, {
    type: 'line',
    data: {
      labels: <%= @evolucao_serie_historica.keys.to_json %>,
      datasets: [{
        label: 'Registros por Ano',
        data: <%= @evolucao_serie_historica.values.to_json %>,
        borderColor: '#4e73df',
        backgroundColor: 'rgba(78, 115, 223, 0.1)',
        fill: true,
        tension: 0.4,
        pointBackgroundColor: '#4e73df',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointRadius: 4,
        pointHoverRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display: false }
      },
      scales: {
        y: { 
          beginAtZero: true,
          grid: { color: 'rgba(0, 0, 0, 0.05)' }
        },
        x: {
          grid: { display: false }
        }
      }
    }
  });

  // Gráfico de Barras - Evolução Metas
  const metasCtx = document.getElementById('metasChart').getContext('2d');
  new Chart(metasCtx, {
    type: 'bar',
    data: {
      labels: <%= @evolucao_metas.keys.to_json %>,
      datasets: [{
        label: 'Metas por Ano',
        data: <%= @evolucao_metas.values.to_json %>,
        backgroundColor: '#1cc88a',
        borderColor: '#1cc88a',
        borderWidth: 0,
        borderRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display: false }
      },
      scales: {
        y: { 
          beginAtZero: true,
          grid: { color: 'rgba(0, 0, 0, 0.05)' }
        },
        x: {
          grid: { display: false }
        }
      }
    }
  });
});
</script>
